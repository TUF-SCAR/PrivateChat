#The database name.
DATABASE_NAME=PrivateChat


#The user in database, default is postgres.
DATABASE_USER=postgres


#The database/login password.
DATABASE_PASSWORD=your_password_here


#The database host, default is localhost.
DATABASE_HOST=localhost


#The database port, default port is 5432
DATABASE_PORT=5432


# Secret key used to sign login tokens.
# Generate one with:
# py -c "import secrets; print(secrets.token_urlsafe(64))"
TOKEN_SECRET_KEY=your_generated_secret_key_here


# Access token expiry time in minutes.
# Example: 60 means the user stays logged in for 1 hour before the token expires.
ACCESS_TOKEN_EXPIRE_MINUTES=60
